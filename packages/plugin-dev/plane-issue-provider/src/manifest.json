{
  "id": "plane-issue-provider",
  "name": "Plane Issues",
  "version": "1.0.0",
  "manifestVersion": 1,
  "minSupVersion": "13.0.0",
  "description": "Plane.so issue provider plugin",
  "author": "Super Productivity",
  "type": "issueProvider",
  "icon": "icon.svg",
  "iFrame": false,
  "permissions": [],
