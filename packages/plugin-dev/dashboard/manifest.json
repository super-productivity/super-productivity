{
  "name": "Dashboard",
  "id": "dashboard",
  "manifestVersion": 1,
  "version": "1.0.0",
  "minSupVersion": "13.0.0",
  "author": "Super Productivity",
  "description": "Overview dashboard showing task progress, current task, and daily activity.",
  "hooks": ["currentTaskChange", "taskComplete", "taskUpdate", "finishDay"],
  "permissions": [
    "getCurrentContextTasks",
    "showIndexHtmlAsView",
    "dispatchAction",
    "persistDataSynced",
    "loadSyncedData"
  ],
  "iFrame": true,
  "sidePanel": true,
  "type": "standard",
  "assets": [],
  "icon": "icon.svg"
}
