{
  "name": "@super-productivity/cli",
  "version": "1.0.0",
  "description": "CLI and HTTP client for Super Productivity",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "super-productivity",
    "cli",
    "task-management",
    "productivity"
  ],
  "author": "Johannes Millan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/super-productivity/super-productivity.git",
    "directory": "packages/cli"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
